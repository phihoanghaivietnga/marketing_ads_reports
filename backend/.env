# ============================================================
# .env.example — copy thành .env rồi điền giá trị thật.
# KHÔNG commit file .env vào git.
# ============================================================

# ---------- App ----------
APP_ENV=development                # development | staging | production
APP_DEBUG=true
API_V1_PREFIX=/api/v1
API_KEY=change-me-to-a-random-secret     # dùng cho header X-API-Key, auth đơn giản đợt 1

# ---------- Database (PostgreSQL) ----------
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://postgres:/marketing_ads_reports

# Pool settings (tuỳ chỉnh nếu cần)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---------- Redis (Celery broker + cache layer) ----------
# Format: redis://<host>:<port>/<db_index>
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- Cache TTL (giây) ----------
CACHE_TTL_RECENT=300      # dùng khi date_to nằm trong 24h gần nhất (data còn có thể update)
CACHE_TTL_HISTORICAL=3600 # dùng khi date range đã "đóng băng"

# ---------- Facebook Marketing API ----------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_API_VERSION=v19.0

# ---------- TikTok Ads API (để trống — dùng ở đợt 2) ----------
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# ---------- Google Ads API (để trống — dùng ở đợt 2) ----------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ---------- Rate limit (mặc định, có thể override theo platform trong code) ----------
RATE_LIMIT_FACEBOOK_PER_MIN=200
RATE_LIMIT_TIKTOK_PER_MIN=100
RATE_LIMIT_GOOGLE_PER_MIN=150
